# ai-reviewers — reviewer authentication config
#
# The plugin carries NO secrets. Each reviewer reads its auth from the
# environment of the machine it runs on. Copy the knobs you need into your shell
# profile (~/.bashrc) or a project .env, then `source` it before launching Claude
# Code (child processes inherit the environment at launch).
#
# A reviewer whose key/flag is absent reports "not configured — set X" and is
# skipped cleanly, rather than failing cryptically mid-run.

# ── API-key reviewers (set the key to enable) ────────────────────────────────
# Kimi (Moonshot) — required for the kimi-reviewer API path (CLI `kimi login` also works).
MOONSHOT_API_KEY=
# DeepSeek — required for the deepseek-reviewer.
DEEPSEEK_API_KEY=

# ── Subscription reviewers (NO API key — they auth via their own CLI login/OAuth;
#    set the flag to true if you have the subscription, so the plugin runs that
#    reviewer and skips the ones you don't) ─────────────────────────────────────
# Codex via ChatGPT/OpenAI subscription. Run `codex login` once, then set:
OPENAI_SUBSCRIPTION=false
# agy / Gemini via Google subscription. Do the agy first-run device-auth once, then set:
GOOGLE_SUBSCRIPTION=false
